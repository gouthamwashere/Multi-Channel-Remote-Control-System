#include <Arduino.h>
#include <SPI.h>
#include <nRF24L01.h>
#include <RF24.h>
#include <MD_MAX72xx.h>
#include <ESP32Servo.h> 

// --- NRF24 PINS ---
const int CE_PIN = 22, CSN_PIN = 5;
RF24 radio(CE_PIN, CSN_PIN); 
const byte address[6] = "00001";

// --- LED MATRIX PINS ---
const int DIN_PIN = 21, CS_PIN = 16, CLK_PIN = 17;

// --- ADDITIONAL HARDWARE PINS ---
const int LED_PIN = 4;      // PIN 4 FIX!
const int SERVO_PIN = 13;   

#define HARDWARE_TYPE MD_MAX72XX::FC16_HW
#define MAX_DEVICES 1
MD_MAX72XX lc = MD_MAX72XX(HARDWARE_TYPE, DIN_PIN, CLK_PIN, CS_PIN, MAX_DEVICES);
Servo myServo;

struct ControlData { 
  int packetID; 
  int joy1X, joy1Y, joy2X, joy2Y, potValue; 
  bool encButton, joy1Button, joy2Button; 
  bool extraButton, sw1, sw2;    
};

struct MotionData { 
  int packetID; 
  float accX, accY, accZ, gyroX, gyroY, gyroZ; 
};

struct SystemData { 
  int packetID; 
  long encoderPos; 
  unsigned long uptime; 
  float batteryVoltage; 
};

ControlData cData; MotionData mData; SystemData sData; 

int snakeX[64], snakeY[64];
int snakeLength = 3;
int currentDir = 1, pendingDir = 1;
int appleX, appleY;
unsigned long lastMoveTime = 0;
const int MOVE_DELAY = 180; 
bool gameOver = false;

float smoothedPot = 0; 
int currentAngle = -1;

unsigned long lastPacketTime = 0;
const int DISCONNECT_TIMEOUT = 500; 

void spawnApple() {
  appleX = random(0, 8); appleY = random(0, 8);
}

void initSnake() {
  snakeLength = 3; currentDir = 1; pendingDir = 1;
  snakeX[0] = 4; snakeY[0] = 4;
  snakeX[1] = 3; snakeY[1] = 4;
  snakeX[2] = 2; snakeY[2] = 4;
  spawnApple(); gameOver = false;
}

void setup() {
  Serial.begin(115200); randomSeed(analogRead(34)); 
  
  lc.begin(); lc.control(MD_MAX72XX::INTENSITY, 8); lc.clear();                           
  pinMode(LED_PIN, OUTPUT);
  myServo.setPeriodHertz(50); myServo.attach(SERVO_PIN, 500, 2400);
  
  SPI.begin(19, 18, 23, 5); 
  if (!radio.begin()) { Serial.println("RX Radio Fail"); while(1); }
  
  radio.setChannel(108);             
  radio.setDataRate(RF24_1MBPS);     
  radio.setPALevel(RF24_PA_LOW);
  
  radio.openReadingPipe(1, address);
  radio.startListening();
  
  initSnake(); Serial.println("--- RX 1 ONLINE: SW1 CONTROL ---");
}

void loop() {
  // ============================================
  // 1. PROCESS RADIO 
  // ============================================
  while (radio.available()) {
    lastPacketTime = millis(); 
    
    uint8_t buffer[32]; uint8_t size = radio.getPayloadSize();
    radio.read(&buffer, size);
    int incomingID = *((int*)buffer);

    if (incomingID == 101) {
      memcpy(&cData, buffer, sizeof(ControlData));

      // -------- MULTI-RECEIVER SELECTOR --------
      // Only process inputs if Toggle Switch 1 is switched ON
      if (cData.sw1 == true) {
        
        // -------- SMOOTHED SERVO CONTROL --------
        smoothedPot = (smoothedPot * 0.90) + (cData.potValue * 0.10);
        int targetAngle = map((int)smoothedPot, 0, 4095, 0, 180);
        
        if (abs(targetAngle - currentAngle) >= 1) {
          currentAngle = targetAngle;
          myServo.write(currentAngle);
        }

        // -------- SNAKE DIRECTION CONTROL (X-Axis Swapped) --------
        if (cData.joy1Y > 3000 && currentDir != 2) pendingDir = 0; 
        else if (cData.joy1Y < 1000 && currentDir != 0) pendingDir = 2; 
        else if (cData.joy1X > 3000 && currentDir != 1) pendingDir = 3; 
        else if (cData.joy1X < 1000 && currentDir != 3) pendingDir = 1; 
        
        if (cData.joy1Button && gameOver) initSnake();
      }
    } 
    else if (incomingID == 102) memcpy(&mData, buffer, sizeof(MotionData));
    else if (incomingID == 103) memcpy(&sData, buffer, sizeof(SystemData));
  }

  // ============================================
  // 2. CONNECTION & ACTIVE LED
  // ============================================
  if (millis() - lastPacketTime > DISCONNECT_TIMEOUT) {
    digitalWrite(LED_PIN, LOW); // DISCONNECTED (LED OFF)
  } else {
    // We are connected! Only light up if THIS receiver is currently active (SW1 is ON)
    if (cData.sw1 == true) {
      digitalWrite(LED_PIN, HIGH);
    } else {
      digitalWrite(LED_PIN, LOW);
    }
  }

  // ============================================
  // 3. SNAKE GAME TICK
  // ============================================
  // Require cData.sw1 == true to let the snake move!
  if (millis() - lastMoveTime > MOVE_DELAY && !gameOver && cData.sw1 == true) {
    lastMoveTime = millis(); currentDir = pendingDir;
    
    for (int i = snakeLength - 1; i > 0; i--) {
      snakeX[i] = snakeX[i-1]; snakeY[i] = snakeY[i-1];
    }
    
    if (currentDir == 0) snakeY[0]--;     
    else if (currentDir == 1) snakeX[0]++;
    else if (currentDir == 2) snakeY[0]++;
    else if (currentDir == 3) snakeX[0]--;
    
    if (snakeX[0] < 0) snakeX[0] = 7; else if (snakeX[0] > 7) snakeX[0] = 0;
    if (snakeY[0] < 0) snakeY[0] = 7; else if (snakeY[0] > 7) snakeY[0] = 0;
    
    for (int i = 1; i < snakeLength; i++) {
      if (snakeX[0] == snakeX[i] && snakeY[0] == snakeY[i]) gameOver = true;
    }
    
    if (snakeX[0] == appleX && snakeY[0] == appleY) {
      snakeLength++; if (snakeLength > 64) snakeLength = 64; 
      spawnApple();
    }
    
    lc.control(MD_MAX72XX::UPDATE, 0); lc.clear();
    
    if (gameOver) {
      lc.setPoint(0,0,1); lc.setPoint(1,1,1); lc.setPoint(6,6,1); lc.setPoint(7,7,1);
      lc.setPoint(0,7,1); lc.setPoint(1,6,1); lc.setPoint(6,1,1); lc.setPoint(7,0,1);
    } else {
      lc.setPoint(appleY, appleX, true); 
      for (int i = 0; i < snakeLength; i++) lc.setPoint(snakeY[i], snakeX[i], true);
    }
    
    lc.control(MD_MAX72XX::UPDATE, 1); 
  }
}
